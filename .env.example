# ==========================================
# Faith Automation Task Manager - Env Template
# ==========================================

# --- BACKEND SETTINGS ---
PORT=5000

# MongoDB Connection String (Atlas Connection Example)
# Replace <username>, <password>, and <cluster-url> with your MongoDB Atlas details.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/faith_automation?retryWrites=true&w=majority

# JWT Token configuration
# Provide a strong, random key in production (e.g. run 'openssl rand -base64 32')
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Frontend URL (For CORS Security)
# In production, set this to your hosted frontend URL (e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173

# --- FRONTEND SETTINGS ---
# Set the backend URL for the React app to communicate with.
# In local development: http://localhost:5000/api
# In production: https://your-backend-service.onrender.com/api
VITE_API_URL=http://localhost:5000/api
